{
  "name": "sharkctl",
  "version": "1.0.0",
  "description": "Attack Shark X11 \u2014 configurador nativo para Linux",
  "main": "out/main/index.js",
  "author": "Clevs",
  "license": "MIT",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder",
    "package": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "dev:sys": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "start": "env -u ELECTRON_RUN_AS_NODE ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 electron-vite preview",
    "postinstall": "node scripts/setup-electron.mjs",
    "test-usb": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/test-usb.js",
    "build:asar": "electron-vite build && npx --yes @electron/asar pack . app.asar --unpack-dir \"node_modules/usb/**\" --exclude-hidden -- out package.json node_modules/usb node_modules/node-addon-api node_modules/node-gyp-build node_modules/pino node_modules/pino-* assets",
    "diag-rgb-safe": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-rgb-safe.js",
    "diag-rgb-mode": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-rgb-mode.js",
    "diag-rgb-stages": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-rgb-stages.js",
    "diag-rgb-stage6": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-rgb-stage6.js",
    "diag-rgb-watch": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-rgb-watch.js",
    "diag-rgb-watch2": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-rgb-watch2.js",
    "diag-anim-params": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-anim-params.js",
    "diag-anim-params2": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-anim-params2.js",
    "diag-long-watch": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-long-watch.js",
    "diag-get-report": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-get-report.js",
    "diag-report03-05": "ELECTRON_OVERRIDE_DIST_PATH=/usr/lib/electron34 node_modules/electron/dist/electron scripts/diag-report03-05.js"
  },
  "build": {
    "appId": "dev.clevs.sharkctl",
    "productName": "SharkCtl",
    "artifactName": "sharkctl-${version}.${ext}",
    "copyright": "Copyright © 2025 Clevs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/usb/**",
      "node_modules/node-gyp-build/**",
      "node_modules/@electron-toolkit/utils/**",
      "!node_modules/usb/prebuilds/android*/**",
      "!node_modules/usb/prebuilds/darwin*/**",
      "!node_modules/usb/prebuilds/win32*/**",
      "!node_modules/usb/prebuilds/linux-arm*/**",
      "!node_modules/usb/prebuilds/linux-ia32/**"
    ],
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/usb/**",
      "node_modules/node-gyp-build/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Settings",
      "icon": "assets/icons"
    },
    "deb": {
      "depends": ["libusb-1.0-0"],
      "afterInstall": "scripts/postinstall-deb.sh",
      "afterRemove": "scripts/postremove-deb.sh"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/chakra-petch": "^5.2.5",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@vitejs/plugin-react": "^6.0.2",
    "pino": "10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "usb": "2.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3"
  }
}