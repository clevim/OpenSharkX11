{
	"name": "attack-shark-x11-driver",
	"version": "1.0.1",
	"description": "A TypeScript driver for the Attack Shark X11 gaming mouse, supporting Linux and other platforms via Node.js/Bun and USB HID.",
	"author": {
		"name": "HarukaYamamoto0",
		"email": "harukayamamotodev@gmail.com",
		"url": "https://harukadev.com"
	},
	"license": "MIT",
	"homepage": "https://github.com/HarukaYamamoto0/attack-shark-x11-driver#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/HarukaYamamoto0/attack-shark-x11-driver.git"
	},
	"bugs": {
		"url": "https://github.com/HarukaYamamoto0/attack-shark-x11-driver/issues"
	},
	"keywords": [
		"attack-shark",
		"x11",
		"mouse",
		"driver",
		"linux",
		"usb",
		"hid",
		"typescript"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"prepublishOnly": "bun run build",
		"build": "bunx tsc",
		"lint": "bunx eslint . --ext .ts --cache --cache-strategy content",
		"lint:fix": "bunx eslint . --ext .ts --fix --cache --cache-strategy content",
		"format": "bunx prettier --check . --cache --cache-strategy content",
		"format:fix": "bunx prettier --write . --cache --cache-strategy content",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"dependencies": {
		"pino": "10.3.1",
		"usb": "2.17.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "1.3.14",
		"@types/node": "^25.9.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.3.2",
		"prettier": "3.8.1",
		"typescript": "^5.5.3",
		"typescript-eslint": "^8.56.1"
	},
	"engines": {
		"bun": "1.3.14"
	}
}
